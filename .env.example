APP_HOST=0.0.0.0
APP_PORT=8787
APP_SESSION_SECRET=change-this-long-random-secret
# Optional. Leave empty to use ./data.
# Ubuntu/systemd recommended:
# APP_DATA_DIR=/var/lib/cpamc-sidecar
# Windows example:
# APP_DATA_DIR=D:\cpamc-sidecar-data

# CPAMC server address. Usually the same origin that serves management.html.
CPAMC_BASE_URL=http://114.132.237.115:8317

# CPAMC management password/key. Keep it only on the server.
CPAMC_MANAGEMENT_KEY=change-this

# Comma separated CPAMC API keys that should become admins when they log in.
# Example: ADMIN_API_KEYS=sk-xxx,sk-yyy
ADMIN_API_KEYS=

# If true, a valid CPAMC API key can self-register as a normal user on first login.
AUTO_CREATE_USERS=true

# If true, login verifies the API key by calling CPAMC /v1/models.
CPAMC_VALIDATE_LOGIN=true

# Local configuration auto backup. Users, roles, aliases, limits and settings are backed up.
AUTO_BACKUP_ENABLED=true
AUTO_BACKUP_RETENTION=14

# Periodically archive CPAMC /v0/management/usage snapshots for long-term history.
USAGE_SNAPSHOT_ENABLED=true
USAGE_SNAPSHOT_INTERVAL_MINUTES=60
USAGE_SNAPSHOT_RETENTION=72
